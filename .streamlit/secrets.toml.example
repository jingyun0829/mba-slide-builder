# ─────────────────────────────────────────────────────────
#  Streamlit secrets template
# ─────────────────────────────────────────────────────────
# Local dev:
#   1. Copy this file to .streamlit/secrets.toml
#   2. Fill in real values
#   3. .streamlit/secrets.toml is gitignored (see .gitignore)
#
# Streamlit Community Cloud:
#   Don't commit secrets.toml. Instead, paste these key=value
#   lines into the app's Secrets UI (Settings → Secrets).
# ─────────────────────────────────────────────────────────

# ── Required: AI keys ─────────────────────────────────────
ANTHROPIC_API_KEY = "sk-ant-..."

# ── Optional but recommended ──────────────────────────────
TAVILY_API_KEY = "tvly-..."        # for web image search and recent examples
ELEVENLABS_API_KEY = "sk_..."      # for the intro-video TTS narration

# ── Beta access control ───────────────────────────────────
# A single public invite code. Tell beta testers to use this.
# Change it any time to invalidate all current users.
INVITE_CODE = "BETA2026"

# How many decks each user can build before being blocked.
# Resets when you change the value or restart the app container.
MAX_DECKS_PER_USER = 3

# ── Optional admin override ───────────────────────────────
# If set, typing this string into the login form gives unlimited
# access for that browser session. Useful for live demos.
# Leave commented out to disable.
# ADMIN_PASS = "change-me-to-something-private"

# ── Optional model overrides ──────────────────────────────
# ANTHROPIC_MODEL = "claude-sonnet-4-6"
